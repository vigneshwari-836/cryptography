class Solution:
    def circularPermutation(self, n: int, start: int) -> list[int]:
        res = []
        # There are 2^n numbers in the sequence
        for i in range(1 << n):
            # Generate standard Gray Code and XOR it with start
            gray_code = i ^ (i >> 1)
            res.append(start ^ gray_code)
        return res
