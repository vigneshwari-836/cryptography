import sys

def brute_force_gcd(a, b):
    # Use absolute values for calculation
    num1 = abs(a)
    num2 = abs(b)

    # GCD(0, n) = n
    if num1 == 0: return num2
    if num2 == 0: return num1

    # The GCD cannot be larger than the smaller of the two numbers
    limit = min(num1, num2)
    gcd_found = 1

    print(f"\n[ANALYSIS] Searching for divisors between 1 and {limit}...")

    for i in range(1, limit + 1):
        # Check if 'i' divides both numbers perfectly
        if num1 % i == 0 and num2 % i == 0:
            gcd_found = i
            print(f"  -> {i} is a common divisor.")

    return gcd_found

def main():
    while True:
        print("\n" + "="*40)
        print("      BRUTE-FORCE GCD CALCULATOR")
        print("="*40)
        print(" (Enter 0 at the first prompt to exit)")

        try:
            # Get first number
            raw_input1 = input("Enter first integer: ").strip()
            if not raw_input1: continue
            val1 = int(raw_input1)

            # Exit condition
            if val1 == 0:
                print("Exiting...")
                break

            # Get second number
            raw_input2 = input("Enter second integer: ").strip()
            if not raw_input2:
                print("Error: Please provide a second number.")
                continue
            val2 = int(raw_input2)

            # Perform calculation
            result = brute_force_gcd(val1, val2)

            print("-" * 40)
            print(f"FINAL GCD VALUE: {result}")
            print("-" * 40)

        except ValueError:
            print("\n[!] INPUT ERROR: Please enter whole integers only (e.g. 12, 48).")
        except EOFError:
            break

if __name__ == "__main__":
    main()

