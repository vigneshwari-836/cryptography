import random

def miller_rabin(n, k=5):
    # Handle base cases
    if n < 2:
        print(f"Intermediate: {n} is less than 2.")
        return False
    if n == 2 or n == 3:
        print(f"Intermediate: {n} is a known small prime.")
        return True
    if n % 2 == 0:
        print(f"Intermediate: {n} is even and > 2, so it is composite.")
        return False

    # Step 1: Find r and d such that n - 1 = 2^r * d
    r, d = 0, n - 1
    while d % 2 == 0:
        r += 1
        d //= 2

    print(f"\n[STEP 1] Decomposition of n-1:")
    print(f"  {n}-1 = 2^{r} * {d}")

    # Step 2: Witness loop
    for i in range(k):
        a = random.randint(2, n - 2)
        print(f"\n[STEP 2.{i+1}] Testing witness a = {a}:")

        # Compute x = a^d % n
        x = pow(a, d, n)
        print(f"  Initial check: {a}^{d} mod {n} = {x}")

        if x == 1 or x == n - 1:
            print(f"  Result: Passed (x is {x}). {n} might be prime.")
            continue

        composite = True
        for j in range(r - 1):
            x = pow(x, 2, n)
            print(f"  Squaring {j+1}: x^2 mod {n} = {x}")
            if x == n - 1:
                print(f"  Result: Passed (reached n-1). {n} might be prime.")
                composite = False
                break

        if composite:
            print(f"  Result: FAILED. {a} is a witness that {n} is COMPOSITE.")
            return False

    return True

def main():
    while True:
        print("\n" + "="*30)
        print("MILLER-RABIN PRIMALITY TEST")
        print("="*30)
        try:
            val = input("Enter a number to test (or 0 to exit): ")
            n = int(val)

            if n == 0:
                print("Exiting...")
                break

            # k is the number of iterations; higher k means higher accuracy
            k = 5
            is_prime = miller_rabin(n, k)

            print("\n" + "-"*30)
            if is_prime:
                print(f"FINAL ANSWER: {n} is PROBABLY PRIME.")
            else:
                print(f"FINAL ANSWER: {n} is COMPOSITE.")
            print("-"*30)

        except ValueError:
            print("Invalid input. Please enter an integer.")

if __name__ == "__main__":
    main()

