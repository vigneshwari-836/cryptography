class Solution:
    def permute(self, nums: list[int]) -> list[list[int]]:
        res = []
        
        def backtrack(current_path, used):
            # Base Case: path is full
            if len(current_path) == len(nums):
                res.append(current_path[:]) # Append a copy
                return
            
            for i in range(len(nums)):
                if not used[i]:
                    # 1. Action: Choose the number
                    used[i] = True
                    current_path.append(nums[i])
                    
                    # 2. Recursion: Move to the next level
                    backtrack(current_path, used)
                    
                    # 3. Backtrack: Undo the choice
                    current_path.pop()
                    used[i] = False
        
        # Initialize helper variables
        backtrack([], [False] * len(nums))
        return res
